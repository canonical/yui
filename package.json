{
    "name": "@canonical/yui",
    "version": "3.18.2",
    "description": "YUI 3 Source (Canonical security-maintained fork)",
    "author": "Dav Glass <davglass@gmail.com>",
    "bugs": {
        "url": "https://github.com/canonical/yui/issues"
    },
    "engines": {
        "node": ">=20"
    },
    "directories": {
        "lib": "."
    },
    "main": "./index.js",
    "devDependencies": {
        "@playwright/test": "^1.61.1",
        "http-server": "^14.1.1",
        "vitest": "^4.1.9"
    },
    "scripts": {
        "test": "vitest run",
        "test:node": "vitest run",
        "test:browser": "playwright test --project=browser",
        "test:legacy": "playwright test --project=legacy",
        "test:all": "vitest run && playwright test",
        "stage-npm": "node scripts/stage-npm.js",
        "publish-npm": "npm run stage-npm && npm publish ./npm-dist"
    },
    "license": "BSD-3-Clause",
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/canonical/yui.git"
    }
}
